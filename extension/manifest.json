{
  "manifest_version": 3,
  "name": "Employee Activity Monitor",
  "version": "1.0.0",
  "description": "Track your daily website activity and sync with admin dashboard",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "webRequest",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Employee Activity Monitor"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"]
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
